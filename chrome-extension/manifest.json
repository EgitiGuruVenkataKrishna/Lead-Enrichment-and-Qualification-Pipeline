{
  "manifest_version": 3,
  "name": "Lead Enricher",
  "version": "1.0",
  "description": "Extracts lead profiles and queues them for real-time enrichment.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
